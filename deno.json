{
  "version": "0.3.6",
  "tasks": {
    "dev": "deno run --env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run --watch daemon/main.ts",
    "start": "deno run --env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run daemon/main.ts",
    "mpt": "deno run --env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run cli/main.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env --allow-ffi tests/",
    "check": "deno check daemon/main.ts daemon/server.ts daemon/store.ts cli/main.ts",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "compile": "cd ui && npm run build && cd .. && deno compile --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run --include ui/dist/ --output mpt main.ts",
    "compile:all": "./scripts/build.sh",
    "compile:darwin-arm64": "./scripts/build.sh darwin-arm64",
    "compile:darwin-x64": "./scripts/build.sh darwin-x64",
    "compile:linux-x64": "./scripts/build.sh linux-x64",
    "compile:linux-arm64": "./scripts/build.sh linux-arm64",
    "compile:windows-x64": "./scripts/build.sh windows-x64"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4",
    "hono/": "jsr:@hono/hono@^4/",
    "@db/sqlite": "jsr:@db/sqlite@^0.12",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/fs/": "jsr:@std/fs@^1/",
    "@std/path": "jsr:@std/path@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
