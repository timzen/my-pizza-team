{
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-env --watch daemon/main.ts",
    "start": "deno run --allow-net --allow-read --allow-env daemon/main.ts",
    "test": "deno test --allow-net --allow-read --allow-env tests/",
    "check": "deno check daemon/main.ts cli/main.ts"
  },
  "imports": {
    "hono": "jsr:@hono/hono@^4",
    "hono/": "jsr:@hono/hono@^4/",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
